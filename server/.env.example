# ─── Server ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT ─────────────────────────────────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Data ────────────────────────────────────────────────────────────
CSV_PATH=./data/sample-readings.csv
USERS_CONFIG_PATH=./users.config.json

# ─── Electrical defaults ─────────────────────────────────────────────
NOMINAL_VOLTAGE=230
RATED_PHASE_CURRENT_A=100
LIVE_TICK_MS=10000

# ─── CORS ────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
